{
  "name": "my-next-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "docker:build": "docker build -t diet-landing:latest .",
    "docker:rebuild": "docker build --no-cache -t diet-landing:latest .",
    "docker:run": "docker run -d -p 3001:3000 --name diet-landing-app diet-landing:latest",
    "docker:stop": "docker stop diet-landing-app && docker rm diet-landing-app",
    "docker:clean": "npm run docker:stop || true && docker rmi diet-landing:latest || true",
    "docker:logs": "docker logs -f diet-landing-app",
    "docker:compose:up": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "docker:compose:rebuild": "docker-compose up -d --build --force-recreate",
    "deploy:plesk": "bash scripts/deploy-plesk.sh"
  },
  "dependencies": {
    "next": "16.0.10",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.34",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "tailwindcss": "^4"
  }
}
